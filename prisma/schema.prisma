generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS
}

model User {
  id           String     @id @default(cuid())
  fullName     String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(RECEPTIONIST)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bookingsCreated    Booking[] @relation("BookingCreatedBy")
  bookingsCheckedIn  Booking[] @relation("BookingCheckedInBy")
  bookingsCheckedOut Booking[] @relation("BookingCheckedOutBy")
  paymentsRecorded   Payment[] @relation("PaymentRecordedBy")
}

model RoomType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms Room[]
}

model Room {
  id            String     @id @default(cuid())
  roomNumber    String     @unique
  pricePerNight Decimal    @db.Decimal(12, 2)
  capacity      Int
  status        RoomStatus @default(AVAILABLE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  roomTypeId String
  roomType   RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  bookings   Booking[]

  @@index([roomTypeId])
  @@index([status])
}

model Guest {
  id          String   @id @default(cuid())
  fullName    String
  phoneNumber String   @unique
  email       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]

  @@index([fullName])
}

model Booking {
  id           String        @id @default(cuid())
  checkInDate  DateTime
  checkOutDate DateTime
  totalAmount  Decimal       @db.Decimal(12, 2)
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  guestId        String
  roomId         String
  createdById    String
  checkedInById  String?
  checkedOutById String?

  guest        Guest    @relation(fields: [guestId], references: [id], onDelete: Restrict)
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdBy    User     @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  checkedInBy  User?   @relation("BookingCheckedInBy", fields: [checkedInById], references: [id], onDelete: Restrict)
  checkedOutBy User?   @relation("BookingCheckedOutBy", fields: [checkedOutById], references: [id], onDelete: Restrict)
  payment      Payment?

  @@index([guestId])
  @@index([roomId])
  @@index([createdById])
  @@index([checkedInById])
  @@index([checkedOutById])
  @@index([status])
  @@index([checkInDate])
  @@index([checkOutDate])
}

model Payment {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  paymentDate DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  bookingId    String @unique
  recordedById String

  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  recordedBy User    @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([recordedById])
  @@index([paymentDate])
}
