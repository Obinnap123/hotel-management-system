# Supabase PostgreSQL connection string.
# Use the pooled connection string for application/runtime queries.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Optional direct connection string for migrations when needed.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Set to false only when local TLS verification fails against your database host.
DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# Auth foundation placeholders. Fill these when authentication is implemented.
AUTH_SECRET="replace-with-a-secure-random-value"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# System user used as the creator for public website reservations.
PUBLIC_BOOKING_CREATED_BY_ID="replace-with-public-website-system-user-id"

# First staff admin seed. Used by `pnpm db:seed`.
SEED_ADMIN_NAME="Hotel Admin"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace-with-a-secure-password"
