# Supabase PostgreSQL connection string.
# Use the pooled connection string for application/runtime queries.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Optional direct connection string for migrations when needed.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Auth foundation placeholders. Fill these when authentication is implemented.
AUTH_SECRET="replace-with-a-secure-random-value"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
